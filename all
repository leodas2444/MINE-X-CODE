#!/usr/bin/env bash
# ==================================================
# MINEX CLOUD • Panel + Blueprint Manager
# ==================================================

set -e

# ---------------- THEME ----------------
PRIMARY='\033[38;5;39m'
SUCCESS='\033[38;5;82m'
WARNING='\033[38;5;214m'
DANGER='\033[38;5;196m'
RESET='\033[0m'

PANEL_DIR="/var/www/pterodactyl"

# ---------------- ROOT CHECK ----------------
if [[ $EUID -ne 0 ]]; then
   echo -e "${DANGER}Run as root (sudo).${RESET}"
   exit 1
fi

# ---------------- UI ----------------
banner() {
clear
echo -e "${PRIMARY}"
echo "====================================="
echo "        MINEX CLOUD MANAGER"
echo "====================================="
echo -e "${RESET}"
}

pause(){
read -p "Press Enter to continue..."
}

# ==================================================
# PANEL INSTALLER
# ==================================================

install_panel(){

banner

read -p "Enter Panel Domain: " DOMAIN
read -p "Enter Admin Email (SSL): " EMAIL

echo "Updating system..."
apt update -y && apt upgrade -y

echo "Installing dependencies..."
apt install -y curl nginx mariadb-server redis-server git unzip software-properties-common

echo "Installing PHP..."
add-apt-repository ppa:ondrej/php -y
apt update

apt install -y php8.2 php8.2-cli php8.2-gd php8.2-mysql php8.2-mbstring \
php8.2-bcmath php8.2-xml php8.2-fpm php8.2-curl php8.2-zip

echo "Downloading Panel..."

mkdir -p $PANEL_DIR
cd $PANEL_DIR

curl -Lo panel.tar.gz https://github.com/pterodactyl/panel/releases/latest/download/panel.tar.gz

tar -xzvf panel.tar.gz
chmod -R 755 storage/* bootstrap/cache/

echo "Installing Composer..."

curl -sS https://getcomposer.org/installer | php
mv composer.phar /usr/local/bin/composer

composer install --no-dev --optimize-autoloader

cp .env.example .env
php artisan key:generate --force

echo "Configuring Nginx..."

cat <<EOF > /etc/nginx/sites-available/pterodactyl.conf
server {
listen 80;
server_name $DOMAIN;

root /var/www/pterodactyl/public;
index index.php;

location / {
try_files \$uri \$uri/ /index.php?\$query_string;
}

location ~ \.php$ {
include snippets/fastcgi-php.conf;
fastcgi_pass unix:/run/php/php8.2-fpm.sock;
}
}
EOF

ln -s /etc/nginx/sites-available/pterodactyl.conf /etc/nginx/sites-enabled/

systemctl restart nginx

echo "Installing SSL..."

apt install certbot python3-certbot-nginx -y
certbot --nginx -d $DOMAIN --non-interactive --agree-tos -m $EMAIL

echo -e "${SUCCESS}Panel Installed → https://$DOMAIN${RESET}"

pause
}

# ==================================================
# PANEL UNINSTALL
# ==================================================

uninstall_panel(){

banner

read -p "Remove Panel? (y/n): " confirm

if [ "$confirm" != "y" ]; then
return
fi

systemctl stop nginx
systemctl stop mariadb

rm -rf /var/www/pterodactyl

rm -f /etc/nginx/sites-enabled/pterodactyl.conf
rm -f /etc/nginx/sites-available/pterodactyl.conf

systemctl restart nginx

echo -e "${SUCCESS}Panel Removed Successfully${RESET}"

pause
}

# ==================================================
# PANEL MENU
# ==================================================

panel_menu(){

while true
do

banner

echo "1) Install Panel"
echo "2) Uninstall Panel"
echo ""
echo "0) Back"

read -p "Select: " opt

case $opt in

1) install_panel ;;
2) uninstall_panel ;;
0) break ;;
*) echo "Invalid"; sleep 1 ;;

esac

done
}

# ==================================================
# BLUEPRINT MENU
# ==================================================

addons_menu(){

while true
do

banner

echo "Blueprint Addons"

echo "1) Recolor Theme"
echo "2) Sidebar Theme"
echo "3) Server Backgrounds"
echo "4) Euphoria Theme"
echo ""
echo "0) Back"

read -p "Select: " opt

case $opt in

1) blueprint -install recolor.blueprint ;;
2) blueprint -install sidebar.blueprint ;;
3) blueprint -install serverbackgrounds.blueprint ;;
4) blueprint -install euphoriatheme.blueprint ;;
0) break ;;
*) echo "Invalid"; sleep 1 ;;

esac

done
}

blueprint_menu(){

while true
do

banner

echo "1) Install Blueprint Framework"
echo "2) Install Addons"
echo "3) Update Extensions"
echo "4) Remove Addon"
echo ""
echo "0) Back"

read -p "Select: " opt

case $opt in

1)
cd $PANEL_DIR
wget https://raw.githubusercontent.com/kiruthik123/panelinstaler/main/blueprint-installer.sh
bash blueprint-installer.sh
;;

2) addons_menu ;;

3)
cd $PANEL_DIR
blueprint -upgrade
;;

4)
read -p "Addon ID: " id
cd $PANEL_DIR
blueprint -remove $id
;;

0) break ;;

esac

done
}

# ==================================================
# MAIN MENU
# ==================================================

while true
do

banner

echo "1) Panel Manager"
echo "2) Blueprint Manager"
echo ""
echo "0) Exit"

read -p "Select Option: " opt

case $opt in

1) panel_menu ;;
2) blueprint_menu ;;
0) exit ;;

*) echo "Invalid"; sleep 1 ;;

esac

done
