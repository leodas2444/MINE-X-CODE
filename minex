# =========================
# COLORS / STYLE
# =========================
B_BLUE='\033[1;38;5;39m'
B_CYAN='\033[1;38;5;51m'
B_PURPLE='\033[1;38;5;135m'
B_GREEN='\033[1;38;5;82m'
B_RED='\033[1;38;5;196m'
B_YELLOW='\033[1;38;5;220m'
B_PINK='\033[1;38;5;213m'
B_WHITE='\033[1;38;5;255m'
GRAY='\033[38;5;245m'
DARK='\033[48;5;236m'
NC='\033[0m'

# =========================
# SYSTEM METRICS
# =========================
get_metrics() {
    CPU=$(top -bn1 | grep "Cpu(s)" | awk '{printf "%.0f", $2+$4}')
    RAM=$(free | grep Mem | awk '{printf "%.0f", $3*100/$2}')
    DISK=$(df -h / | awk 'NR==2 {print $5}')
    HOST=$(hostname)
    KERNEL=$(uname -r)
    UPTIME=$(uptime -p | sed 's/up //')
    IP=$(curl -s ifconfig.me 2>/dev/null)
}

# =========================
# PROGRESS BAR
# =========================
progress_bar() {
    local percent=$1
    local filled=$((percent / 5))
    local empty=$((20 - filled))

    printf "${B_GREEN}"
    for ((i=0; i<filled; i++)); do printf "█"; done
    printf "${GRAY}"
    for ((i=0; i<empty; i++)); do printf "░"; done
    printf "${NC} ${B_WHITE}%s%%%s" "$percent" "${NC}"
}

