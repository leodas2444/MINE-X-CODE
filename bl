#!/bin/bash

# ==========================================
# 🎨 UI CONFIGURATION & COLORS
# ==========================================
R="\e[31m"; G="\e[32m"; Y="\e[33m"
B="\e[34m"; M="\e[35m"; C="\e[36m"
W="\e[97m"; N="\e[0m"

BR="\e[1;31m"; BG="\e[1;32m"; BY="\e[1;33m"
BB="\e[1;34m"; BM="\e[1;35m"; BC="\e[1;36m"
BW="\e[1;97m"
UL="\e[4m"
BLINK="\e[5m"

BG_BLUE="\e[44m"
BG_RED="\e[41m"

# ==========================================
# 🛠️ HELPER FUNCTIONS
# ==========================================

trap 'echo -e "\n${R} [!] Force exit detected.${N}"; exit 1' SIGINT

print_center() {
    local text="$1"
    local width=60
    local padding=$(( (width - ${#text}) / 2 ))
    printf "%*s%s%*s\n" $padding "" "$text" $padding ""
}

header() {
  clear
  echo -e "${BC}"
  echo " ╔══════════════════════════════════════════════════════════╗"
  echo " ║                                                          ║"
  printf " ║${BW}%-58s${BC}║\n" "$(print_center "⚡ MINE X CONTROL HUB ⚡")"
  echo " ║                                                          ║"
  printf " ║${B}%-58s${BC}║\n" "$(print_center "MINE X • Server Tools Panel")"
  echo " ║                                                          ║"
  echo " ╚══════════════════════════════════════════════════════════╝"
  echo -e "${N}"

  echo -e " ${B}User:${N} $(whoami)  ${B}Host:${N} $(hostname)  ${B}Date:${N} $(date +'%H:%M')"
  echo -e "${C} ──────────────────────────────────────────────────────────${N}"
}

pause() {
  echo
  echo -e "${B} ──────────────────────────────────────────────────────────${N}"
  read -rp " ↩️  Press Enter to return to main menu..."
}

# ==========================================
# 📋 ACTIONS
# ==========================================

blueprint1() {
  header
  echo -e "\n${BG} [ ACTION STARTED ] ${N} ${W}Running MINE X Tool 1...${N}\n"
  bash <(curl -s https://raw.githubusercontent.com/leodas2444/MINEX/refs/heads/main/srv/thame/blueprint.sh)
  pause
}

blueprint2() {
  header
  echo -e "\n${BY} [ ACTION STARTED ] ${N} ${W}Running MINE X Tool 2 (Rebuild)...${N}\n"
  bash <(curl -s https://raw.githubusercontent.com/leodas2444/MINEX/refs/heads/main/srv/thame/blueprint-2.sh)
  pause
}

autofix() {
    header
    echo -e "\n${BM} [ DIAGNOSTICS ] ${N} ${W}Attempting Auto-Fix...${N}\n"
    bash <(curl -s https://raw.githubusercontent.com/leodas2444/MINEX/refs/heads/main/srv/thame/fix.sh)
    pause
}

# ==========================================
# 🖥️ MAIN MENU
# ==========================================

show_menu() {
  header
  echo -e "${BW} SELECT AN OPTION:${N}\n"

  echo -e "  ${BG}[ 1 ]${N}  🚀  Install MINE X Tool 1"
  echo -e "  ${BY}[ 2 ]${N}  ⚡  Install MINE X Tool 2 (Fresh Rebuild)"
  echo -e "  ${BM}[ 3 ]${N}  🛠️  Auto Fix / Repair"
  echo ""
  echo -e "  ${BR}[ 0 ]${N}  ❌  Exit Panel"
  
  echo -e "\n${C} ──────────────────────────────────────────────────────────${N}"
}

# ==========================================
# 🔄 EXECUTION LOOP
# ==========================================

while true; do
  show_menu
  read -p " 👉 Enter your choice: " opt

  case $opt in
    1) blueprint1 ;;
    2) blueprint2 ;;
    3) autofix ;;
    0)
       echo -e "\n${M} 👋 Exiting MINE X Panel...${N}"
       sleep 0.5
       clear
       exit
       ;;
    *)
       echo -e "\n${R} ❌ Invalid Option! Please try again.${N}"
       sleep 1
       ;;
  esac
done
