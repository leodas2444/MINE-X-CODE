#!/usr/bin/env bash
# ==========================================================
#  MINEX CLOUD SYSTEM | CORE-LINK
# ==========================================================
set -euo pipefail

# COLORS
R='\033[1;31m'
G='\033[1;32m'
Y='\033[1;33m'
C='\033[1;36m'
W='\033[1;37m'
DG='\033[1;90m'
NC='\033[0m'

# CONFIG
HOST="run.minexcloud.in"
URL="https://${HOST}/payload.sh"
NETRC="${HOME}/.netrc"
NODE_IP="$(hostname -I | awk '{print $1}')"

draw_banner() {
clear
echo -e "${C}"
cat << "EOF"
███╗   ███╗██╗███╗   ██╗███████╗██╗  ██╗     ██████╗██╗      ██████╗ ██╗   ██╗██████╗ 
████╗ ████║██║████╗  ██║██╔════╝╚██╗██╔╝    ██╔════╝██║     ██╔═══██╗██║   ██║██╔══██╗
██╔████╔██║██║██╔██╗ ██║█████╗   ╚███╔╝     ██║     ██║     ██║   ██║██║   ██║██║  ██║
██║╚██╔╝██║██║██║╚██╗██║██╔══╝   ██╔██╗     ██║     ██║     ██║   ██║██║   ██║██║  ██║
██║ ╚═╝ ██║██║██║ ╚████║███████╗██╔╝ ██╗    ╚██████╗███████╗╚██████╔╝╚██████╔╝██████╔╝
╚═╝     ╚═╝╚═╝╚═╝  ╚═══╝╚══════╝╚═╝  ╚═╝     ╚═════╝╚══════╝ ╚═════╝  ╚═════╝ ╚═════╝ 
EOF
echo -e "${NC}"
echo -e "   ${R}──[ ${W}MINEX CORE${R} ]${NC}${DG}────────────────────────────────────────${NC}"
echo -e "   ${DG}NODE:${NC} ${W}$NODE_IP${NC} ${R}│${NC} ${DG}STATUS:${NC} ${G}ONLINE${NC}"
echo ""
}

draw_banner

# Setup auth
echo -ne "   ${R}➤${NC} ${W}Linking MineX Cloud...${NC}"
touch "$NETRC"
chmod 600 "$NETRC"
sed -i "/$HOST/d" "$NETRC" 2>/dev/null || true
printf "machine %s login %s password %s\n" "$HOST" "$NODE_IP" "minex-auth" >> "$NETRC"
sleep 1
echo -e " ${G}[SUCCESS]${NC}"

# Connect to server
echo -ne "   ${R}➤${NC} ${W}Connecting to MineX Network...${NC} "

payload=$(mktemp)
trap "rm -f $payload" EXIT

if curl -fsSL --netrc -A "MineX-Agent" -o "$payload" "$URL"; then
    echo -e "${G}CONNECTED${NC}"
    echo -e "   ${DG}────────────────────────────────────────────────────${NC}"
    echo -e "   ${W}Launching MineX System...${NC}"
    sleep 2
    bash "$payload"
else
    echo -e "${R}FAILED${NC}"
    echo -e "   ${R}[!]${NC} Unable to reach MineX server."
    exit 1
fi
