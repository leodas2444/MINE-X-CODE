# ---------------- INSTALL ADDON ----------------
install_addon() {

name=$1
file=$2
url="$BASE_URL/$file"

banner

echo -e "${WARNING}Installing: $name${RESET}"

if ! command -v blueprint &> /dev/null
then
echo -e "${DANGER}Blueprint framework not installed.${RESET}"
pause
return
fi

cd $PANEL_DIR || return

loading

run_cmd "Downloading addon" "wget -q $url -O $file"

if [ ! -f $file ]; then
echo "Download failed"
pause
return
fi

run_cmd "Installing addon" "blueprint -install $file"

rm -f $file

echo -e "${SUCCESS}$name installed.${RESET}"

pause

}

