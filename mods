# ---------------- UNINSTALL ADDON ----------------
remove_addon() {

banner

read -p "Enter addon ID to remove: " id

cd $PANEL_DIR || return

run_cmd "Removing addon" "blueprint -remove $id"

pause

}

# ---------------- INSTALL FRAMEWORK ----------------
install_framework() {

banner

read -p "Install Blueprint framework? (y/n): " confirm

if [[ $confirm =~ ^[Yy]$ ]]
then

cd $PANEL_DIR || return

run_cmd "Downloading installer" "wget -q $BLUEPRINT_INSTALLER_URL -O blueprint-installer.sh"

run_cmd "Running installer" "bash blueprint-installer.sh"

rm -f blueprint-installer.sh

echo -e "${SUCCESS}Blueprint installed${RESET}"

pause

fi

}

# ---------------- UPDATE EXTENSIONS ----------------
update_extensions() {

banner

cd $PANEL_DIR || return

run_cmd "Updating extensions" "blueprint -upgrade"

pause

}

